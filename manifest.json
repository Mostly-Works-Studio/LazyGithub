{
  "manifest_version": 3,
  "name": "LazyDeploy: Deploy Directly From GitHub PRs",
  "description": "Trigger build and deployment workflows directly from GitHub PR comments — no tab switching, no copy-pasting.",
  "version": "1.0",
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "author": "Mostly Works Studio",
  "permissions": ["storage"],
  "host_permissions": ["https://api.github.com/*"],
  "content_scripts": [{
    "matches": ["*://github.com/*"],
    "js": ["content.js"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "LazyDeploy Settings",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
