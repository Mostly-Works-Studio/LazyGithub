{
  "manifest_version": 3,
  "name": "LazyGitHub: Shortcuts & Automations",
  "description": "Inject one-click shortcuts & automations into GitHub pages: trigger workflows, post comments, dispatch actions anything with ease.",
  "version": "1.1.1",
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png",
    "256": "icon256.png",
    "512": "icon512.png"
  },
  "author": "Mostly Works Studio",
  "permissions": ["storage"],
  "host_permissions": ["https://api.github.com/*"],
  "content_scripts": [{
    "matches": ["*://github.com/*"],
    "js": ["config-defaults.js", "content.js"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "LazyGitHub Settings",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
